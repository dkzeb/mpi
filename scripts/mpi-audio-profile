#!/usr/bin/env bash
set -euo pipefail

mode="${1:-}"
user_name="${MPI_USER:-mpi}"
uid="$(id -u "$user_name")"
runtime="/run/user/$uid"

set_metadata() {
  runuser -u "$user_name" -- env XDG_RUNTIME_DIR="$runtime" \
    pw-metadata -n settings 0 "$1" "$2" >/dev/null
}

if [[ "$mode" != reset ]]; then
  for _ in $(seq 1 50); do
    [[ -S "$runtime/pipewire-0" ]] && break
    sleep 0.1
  done
fi

case "$mode" in
  maschinepi)
    set_metadata clock.force-rate 48000
    set_metadata clock.force-quantum 64
    for governor in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
      [[ -w "$governor" ]] && printf '%s\n' performance > "$governor" || true
    done
    ;;
  mixxx)
    set_metadata clock.force-rate 48000
    set_metadata clock.force-quantum 256
    ;;
  reset)
    [[ -S "$runtime/pipewire-0" ]] || exit 0
    set_metadata clock.force-rate 0
    set_metadata clock.force-quantum 0
    ;;
  *)
    echo "Usage: mpi-audio-profile {maschinepi|mixxx|reset}" >&2
    exit 2
    ;;
esac
